generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id        Int      @id @default(autoincrement())
  hn        String   @unique
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Appointment Appointment[]
}

model Employee {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  role      String   @default("NURSE") // DOCTOR, NURSE, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Timeslot Timeslot[]
}

model Timeslot {
  id          Int      @id @default(autoincrement())
  doctorId    Int
  startTime   DateTime
  endTime     DateTime
  maxCapacity Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Doctor Employee @relation(fields: [doctorId], references: [id])
  Appointments Appointment[]
}

model Appointment {
  id         Int               @id @default(autoincrement())
  patientId  Int
  timeslotId Int
  status     String            @default("BOOKED") // BOOKED, CANCELLED, COMPLETED
  date       DateTime          @default(now())
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  Patient  Patient  @relation(fields: [patientId], references: [id])
  Timeslot Timeslot @relation(fields: [timeslotId], references: [id])

  @@unique([patientId, timeslotId]) // Prevent exact duplicates for same patient on same timeslot
}
